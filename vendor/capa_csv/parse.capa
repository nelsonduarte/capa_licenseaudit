// capa_csv.parse
//
// The RFC 4180 parser: a single character-by-character state
// machine over the input String. Zero capabilities.
//
// What it handles, per RFC 4180:
//   - fields separated by the dialect delimiter
//   - records separated by LF or CRLF (a bare CR not followed
//     by LF is treated as an ordinary record terminator too,
//     which is lenient but never loses data)
//   - quoted fields ("...") in which the delimiter, CR and LF
//     are literal field content
//   - a doubled quote ("") inside a quoted field decodes to a
//     single quote
//   - empty fields, and a trailing delimiter producing a
//     trailing empty field
//   - a final record with or without a terminating newline
//
// Decisions, documented in the README:
//   - a wholly empty line between records is skipped (it yields
//     no Row), matching how real tabular consumers treat blank
//     lines; Python's csv module instead yields a zero-field
//     row, a difference this library deliberately does not copy.
//   - whitespace is significant; fields are not trimmed.
//
// Malformed input never crashes: an unterminated quoted field
// or stray text after a closing quote returns a typed `Err`.

import capa_csv.model

// Character access returns Option<String>; at a known-valid
// index we want the bare character. `at` centralises that
// (the index is always < length() at every call site).
fun at(s: String, i: Int) -> String
    return match s.char_at(i)
        Some(c) -> c
        None    -> ""

/// Parse CSV text with the default comma dialect.
pub fun parse(text: String) -> Result<Table, CsvError>
    return parse_with(text, comma())

/// Parse CSV text with an explicit dialect.
pub fun parse_with(text: String, dialect: Dialect) -> Result<Table, CsvError>
    let delim = dialect.delimiter
    if delim.length() != 1
        return Err(BadDialect("delimiter must be exactly one character, got '${delim}'"))
    if delim == "\""
        return Err(BadDialect("delimiter cannot be the quote character"))
    if delim == "\n" or delim == "\r"
        return Err(BadDialect("delimiter cannot be a newline character"))

    var rows: List<Row> = []
    let n = text.length()

    // Record-building state, reset after each record is emitted.
    var fields: List<String> = []
    var field = ""
    var field_started = false   // any field begun on this record?
    var record_no = 1

    var i = 0
    while i < n
        let c = at(text, i)

        if c == "\""
            // Quoted field. It must start a fresh, empty field;
            // a quote after content (e.g. ab"c) is malformed.
            if not field.is_empty()
                return Err(UnexpectedChar(record_no))
            let res = scan_quoted(text, i + 1, record_no)
            match res
                Err(e) -> return Err(e)
                Ok(q)  ->
                    field = q.value
                    field_started = true
                    i = q.next
                    // After a closing quote only a delimiter or a
                    // record terminator (or end of input) is legal.
                    if i < n
                        let after = at(text, i)
                        if after != delim and after != "\n" and after != "\r"
                            return Err(UnexpectedChar(record_no))
            continue

        if c == delim
            fields.push(field)
            field = ""
            field_started = true
            i = i + 1
            continue

        if c == "\n" or c == "\r"
            // End of record. Consume CRLF as one terminator.
            var j = i + 1
            if c == "\r" and j < n and at(text, j) == "\n"
                j = j + 1
            // Emit the record unless the whole line was empty.
            if field_started or not field.is_empty()
                fields.push(field)
                rows.push(Row { fields: fields })
            fields = []
            field = ""
            field_started = false
            record_no = record_no + 1
            i = j
            continue

        // Ordinary character.
        field = field + c
        field_started = true
        i = i + 1

    // Flush a final record that had no terminating newline.
    if field_started or not field.is_empty()
        fields.push(field)
        rows.push(Row { fields: fields })

    return Ok(Table { rows: rows })

// The outcome of scanning one quoted field: its decoded value
// and the index just past the closing quote.
type Quoted {
    value: String,
    next: Int
}

// Scan a quoted field whose opening quote was at `start - 1`.
// Doubled quotes collapse; the delimiter, CR and LF are literal.
// Runs to the matching close quote or fails with UnclosedQuote.
fun scan_quoted(text: String, start: Int, record_no: Int) -> Result<Quoted, CsvError>
    let n = text.length()
    var value = ""
    var i = start
    while i < n
        let c = at(text, i)
        if c == "\""
            // A doubled quote is an escaped literal quote.
            let j = i + 1
            if j < n and at(text, j) == "\""
                value = value + "\""
                i = i + 2
                continue
            // Otherwise this quote closes the field.
            return Ok(Quoted { value: value, next: i + 1 })
        value = value + c
        i = i + 1
    return Err(UnclosedQuote(record_no))
