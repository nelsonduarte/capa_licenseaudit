// capa_csv.header
//
// The header view: take the first record of a Table as column
// names and address later records' fields by column name.
// Zero capabilities; pure data over a parsed Table.
//
// A `HeaderTable` keeps the column names and the data rows
// (every record after the first). Field access by name returns
// a typed error for an unknown column or a row too short to
// hold that column, never a crash.

import capa_csv.model
import capa_csv.parse

/// A Table viewed through its header: column names plus the
/// data records that follow them.
pub type HeaderTable {
    columns: List<String>,
    rows: List<Row>
}

/// Parse CSV text and take its first record as the header.
/// Empty input yields an empty header and no rows.
pub fun parse_headed(text: String) -> Result<HeaderTable, CsvError>
    return parse_headed_with(text, comma())

/// Parse with an explicit dialect, first record as the header.
pub fun parse_headed_with(text: String, dialect: Dialect) -> Result<HeaderTable, CsvError>
    let table = parse_with(text, dialect)?
    return Ok(from_table(table))

/// Build a header view from an already-parsed Table. The first
/// record becomes the columns; the rest become the data rows.
pub fun from_table(table: Table) -> HeaderTable
    var cols: List<String> = []
    var data: List<Row> = []
    var first = true
    for row in table.rows
        if first
            cols = row.fields
            first = false
        else
            data.push(row)
    return HeaderTable { columns: cols, rows: data }

impl HeaderTable
    /// The number of data records (header excluded).
    pub fun length(self) -> Int
        return self.rows.length()

    /// The zero-based index of a column, or None if absent.
    pub fun column_index(self, name: String) -> Option<Int>
        var i = 0
        for col in self.columns
            if col == name
                return Some(i)
            i = i + 1
        return None

    /// Whether the header declares a column by this name.
    pub fun has_column(self, name: String) -> Bool
        return match self.column_index(name)
            Some(_) -> true
            None    -> false

    /// The value of `column` in data record `row_index`
    /// (zero-based, header excluded). Errors with `NoSuchColumn`
    /// when the header has no such column, with `NoSuchRow` when
    /// there is no data record at `row_index`, and with `ShortRow`
    /// when the record exists but has fewer fields than the
    /// column's index.
    pub fun get(self, row_index: Int, column: String) -> Result<String, CsvError>
        let idx = match self.column_index(column)
            Some(i) -> i
            None    -> return Err(NoSuchColumn(column))
        let row = match self.rows.get(row_index)
            Some(r) -> r
            None    -> return Err(NoSuchRow(row_index))
        return match row.fields.get(idx)
            Some(v) -> Ok(v)
            None    -> Err(ShortRow(column))
